.hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    background-image: url('https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=2075&q=80');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    color: var(--text-light);
    overflow: hidden;
}

.overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom right,
            rgba(15, 23, 42, 0.8),
            rgba(35, 61, 111, 0.6));
    z-index: 1;
}

.content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    animation: heroFadeIn 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.title {
    font-size: 4.5rem;
    line-height: 1.1;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -1.5px;
}

.title span {
    color: var(--accent-color);
    display: block;
}

.subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    color: #e2e8f0;
    margin-bottom: 3rem;
    max-width: 600px;
}

.actions {
    display: flex;
    gap: 1.5rem;
}

.primaryBtn,
.secondaryBtn {
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    cursor: pointer;
    text-align: center;
}

.primaryBtn {
    background-color: var(--accent-color);
    color: var(--primary-color);
    box-shadow: 0 10px 30px rgba(236, 208, 31, 0.3);
}

.primaryBtn:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(236, 208, 31, 0.4);
}

.secondaryBtn {
    background-color: transparent;
    color: var(--bg-color);
    border: 1px solid rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(5px);
}

.secondaryBtn:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: var(--bg-color);
}

@keyframes heroFadeIn {
    from {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@media (max-width: 768px) {
    .content {
        margin-top: 40px;
        /* Leave space for the header */
    }

    .title {
        font-size: 3rem;
        letter-spacing: -1px;
        margin-bottom: 1rem;
    }

    .subtitle {
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    .actions {
        flex-direction: column;
        gap: 1rem;
    }

    .primaryBtn,
    .secondaryBtn {
        font-size: 1rem;
        padding: 0.8rem 1.5rem;
    }
}