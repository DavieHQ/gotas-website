.section {
    padding: 8rem 0;
    background-color: var(--bg-color);
    position: relative;
}

.header {
    text-align: center;
    margin-bottom: 5rem;
    max-width: 600px;
    margin-inline: auto;
}

.tagline {
    color: var(--secondary-color);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    font-size: 0.9rem;
}

.heading {
    font-size: 3.5rem;
    color: var(--primary-color);
    margin-bottom: 1.5rem;
    font-weight: 800;
    letter-spacing: -1px;
}

.description {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.8;
}

.cardsContainer {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-bottom: 5rem;
}

.card {
    background: white;
    padding: 3rem 2rem;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 50px rgba(13, 143, 209, 0.15);
}

.iconWrapper {
    width: 80px;
    height: 80px;
    background-color: rgba(13, 143, 209, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: background-color 0.4s ease, transform 0.4s ease;
}

.icon {
    font-size: 2rem;
    transition: transform 0.4s ease;
}

.card:hover .iconWrapper {
    background-color: var(--primary-color);
}

.card:hover .icon {
    transform: scale(1.1);
}

.card h3 {
    color: var(--primary-color);
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    font-weight: 700;
}

.card a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    transition: color 0.3s ease;
    line-height: 1.5;
}

.card a:hover {
    color: var(--secondary-color);
}

.mapContainer {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.1);
    border: 5px solid white;
    transform: translateZ(0);
}

@media (max-width: 992px) {
    .cardsContainer {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .cardsContainer {
        grid-template-columns: 1fr;
    }

    .heading {
        font-size: 2.5rem;
    }
}