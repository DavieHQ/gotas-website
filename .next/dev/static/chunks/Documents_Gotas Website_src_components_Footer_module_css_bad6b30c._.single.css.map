.footer {
    background-color: var(--bg-dark);
    color: var(--text-light);
    padding-top: 5rem;
}

.grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 3rem;
    padding-bottom: 4rem;
}

.brand h2 {
    font-size: 2rem;
    color: var(--bg-color);
    margin-bottom: 1rem;
}

.brand p {
    color: #94a3b8;
    line-height: 1.6;
    max-width: 400px;
}

.linksBlock,
.contactBlock {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.linksBlock h3,
.contactBlock h3 {
    font-size: 1.25rem;
    color: var(--bg-color);
    margin-bottom: 0.5rem;
}

.linksBlock a,
.contactBlock a,
.contactBlock p {
    color: #cbd5e1;
    transition: color 0.3s ease;
    font-size: 0.95rem;
}

.linksBlock a:hover,
.contactBlock a:hover {
    color: var(--accent-color);
}

.bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 2rem 0;
    text-align: center;
    color: #64748b;
    font-size: 0.875rem;
}

@media (max-width: 768px) {
    .grid {
        grid-template-columns: 1fr;
        gap: 2rem;
    }
}